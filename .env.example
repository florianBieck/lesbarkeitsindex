COMPOSE_PROJECT_NAME=lesbarkeitsindex-prod

# Database
DATABASE_URL=postgresql://admin:admin@localhost:5432/lesbarkeitsindex?schema=public

# R NLP sidecar (Docker only — use localhost for local dev)
R_SIDECAR_URL=http://localhost:8787

# Auth — IMPORTANT: Use a strong random value in production (openssl rand -base64 32)
BETTER_AUTH_SECRET=dev-secret
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated admin emails. Empty = any logged-in user is admin.
ADMIN_EMAILS=
