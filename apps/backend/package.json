    "better-auth": "^1.4.5",
    "dotenv": "^17.4.1",
    "pg": "^8.16.3",
    "prisma": "^7.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.25.0"
  },
