{
  "name": "lesbarkeitsindex",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "vp run -r dev",
    "dev:backend": "pnpm --filter backend run dev",
    "dev:frontend": "pnpm --filter frontend run dev",
    "build": "pnpm --filter backend run build",
    "test": "vp run -r test",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check",
    "generate": "pnpm --filter backend run generate",
    "migrate": "pnpm --filter backend run migrate"
  },
  "devDependencies": {
    "vite-plus": "^0.1.16"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild",
      "@parcel/watcher",
      "unrs-resolver",
      "@nestjs/core",
      "@swc/core"
    ]
  }
}
